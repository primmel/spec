reference R60-1-5-7-1 { document "OIML R 60-1:2021" clause "5.7.1" title "Disturbances — general" }
reference R60-1-5-7-2-1 { document "OIML R 60-1:2021" clause "5.7.2.1" title "Warm-up time" }
