reference R60-1-5-3-1 { document "OIML R 60-1:2021" clause "5.3.1" title "Maximum permissible errors per accuracy class" }
reference R60-1-5-3-2 { document "OIML R 60-1:2021" clause "5.3.2" title "MPE on type evaluation" }
