form MarkingExamination {
  name "MarkingExamination (r60-3/sec-5.1)"
  description "Marking requirements examination (R 60-1, 6.2)"
  conformance_process conf_examinations_inscriptions
  field mandatory_markings_on_load_cell : array {
    items {
      type object
      fields {
        field r60_reference : string { label "R 60 reference" }
        field information : string { label "Information" }
        field fulfils_requirements : enum { label "Fulfils requirements" values [yes, no] }
      }
    }
  }
  field mandatory_markings_on_load_cell_or_document : array {
    items {
      type object
      fields {
        field r60_reference : string { label "R 60 reference" }
        field information : string { label "Information" }
        field on_load_cell : enum { label "On load cell" values [yes, no] }
        field in_document : enum { label "In document" values [yes, no] }
        field fulfils_requirements : enum { label "Fulfils requirements" values [yes, no] }
      }
    }
  }
  pass_fail {
    criteria "All mandatory markings present and correct"
    pass_if "ocl{every(fulfils_requirements) = 'yes'}"
  }
}

form ModelRangeInfo {
  name "ModelRangeInfo (r60-3/sec-4.11)"
  description "Documentation of the model range — various designs within the model range, relevant photographs of the range, definition of load cell families/construction, load cell dimensions within the family, and"
  field model_range_designs : array {
    items {
      type object
      fields {
        field designation : string { label "Design designation" measurement_method declared }
        field description : text { label "Description" measurement_method declared }
        field capacities : string { label "Capacities covered" measurement_method declared }
      }
    }
  }
  field family_definition : object {
    field construction_type : string { label "Construction type" measurement_method declared }
    field sealing_method : string { label "Sealing method" measurement_method declared }
    field strain_gauge_type : string { label "Strain gauge type" measurement_method declared }
    field material : string { label "Material" measurement_method declared }
  }
  field dimensions : array {
    items {
      type object
      fields {
        field model_designation : string { label "Model designation" measurement_method declared }
        field height : number { label "Height" unit "mm" measurement_method declared }
        field diameter : number { label "Diameter (or width)" unit "mm" measurement_method declared }
        field weight : number { label "Weight" unit "kg" measurement_method declared }
        field drawing_reference : string { label "Drawing reference" measurement_method declared }
      }
    }
  }
  field recommended_load_transmissions : array {
    items {
      type object
      fields {
        field load_direction : enum { label "Load direction" measurement_method declared values [compression, tension, beam, universal] }
        field mounting_hardware : string { label "Mounting hardware" measurement_method declared }
        field loading_fixture : string { label "Loading fixture" measurement_method declared }
        field notes : text { label "Notes" measurement_method declared }
      }
    }
  }
}

form PerformanceTestSummary {
  name "PerformanceTestSummary (r60-3/sec-6.1)"
  description "Results of the performance tests — data-derived from test form instances"
  field base_tests : array {
    items {
      type object
      fields {
        field form_id : string { label "Form" }
        field clause : string { label "Clause" }
        field test_name : string { label "Performance Test" required true }
        field temperature : string { label "Temperature" }
        field page_no : string { label "Report Page No." }
        field max_error_v : number { label "Max Error (v)" unit "v" }
        field passed : boolean { label "Passed" }
        field failed : boolean { label "Failed" }
        field remark : string { label "Remark" }
      }
    }
  }
  field electronic_tests : array {
    items {
      type object
      fields {
        field form_id : string { label "Form" }
        field clause : string { label "Clause" }
        field test_name : string { label "Performance Test" required true }
        field temperature : string { label "Temperature" }
        field page_no : string { label "Report Page No." }
        field max_error_v : number { label "Max Error (v)" unit "v" }
        field passed : boolean { label "Passed" }
        field failed : boolean { label "Failed" }
        field remark : string { label "Remark" }
      }
    }
  }
}

form PhotographsInfo {
  name "PhotographsInfo (r60-3/sec-4.10)"
  description "Photographs of the test pattern taken during examination and tests. Per R 60-3 §4 (Evaluation Report), photographs document the physical state of the load cell during key testing phases. "
  field photographs : array {
    items {
      type object
      fields {
        field description : text { label "Description" measurement_method direct }
        field file : string { label "Photograph file" measurement_method direct }
        field date_taken : date { label "Date taken" measurement_method direct }
        field test_phase : enum { label "Test phase" measurement_method direct values [pre_test, during_test, post_test, examination, other] }
      }
    }
  }
  field remarks : text { label "Remarks" measurement_method direct }
}

form PowerVoltage {
  name "PowerVoltage (r60-3/form-6.12)"
  description "Power voltage variation test"
  conformance_process conf_electronic_tests_power_voltage
  field conversion_factor_f : number { label "Conversion Factor F" unit "counts/v" required true }
  field main_voltage : string { label "Main Voltage" required true }
  field supply_type : enum { label "Supply Type" required true values [AC, DC] }
  field preloads : array {
    items {
      type object
      fields {
        field test_load : string { label "Test Load" }
        field indication : number { label "Indication" unit "counts" }
        field time : string { label "Time" }
      }
    }
  }
  field voltage_tests : object {
    field initial_run : object {
      field dmin_indication : number { label "Dmin Indication" }
      field dmax_indication : number { label "Dmax Indication" }
      field span_counts : number { label "Span Counts" calculation ocl{dmax_indication - dmin_indication} }
      field span_vmin : number { label "Span Vmin" calculation ocl{span_counts / conversion_factor_f} }
    }
    field lower_limit : object {
      field dmin_indication : number { label "Dmin Indication" }
      field dmax_indication : number { label "Dmax Indication" }
      field span_counts : number { label "Span Counts" calculation ocl{dmax_indication - dmin_indication} }
      field span_vmin : number { label "Span Vmin" calculation ocl{span_counts / conversion_factor_f} }
      field change : number { label "Change" calculation ocl{span_vmin - initial_run.span_vmin} }
    }
    field upper_limit : object {
      field dmin_indication : number { label "Dmin Indication" }
      field dmax_indication : number { label "Dmax Indication" }
      field span_counts : number { label "Span Counts" calculation ocl{dmax_indication - dmin_indication} }
      field span_vmin : number { label "Span Vmin" calculation ocl{span_counts / conversion_factor_f} }
      field change : number { label "Change" calculation ocl{span_vmin - initial_run.span_vmin} }
    }
    field mpc : number { label "Mpc" unit "v_min" calculation ocl{abs(lookup_mpe(dmax, accuracy_class, plc))} }
  }
  field overall_result : enum { label "Overall Result" required true values [pass, fail] }
  pass_fail {
    criteria "Change of span must not exceed v_min at lower/upper voltage limits"
    pass_if "ocl{abs(lower_limit.change) <= mpc and abs(upper_limit.change) <= mpc}"
  }
}

form Repeatability {
  name "Repeatability (r60-3/table-6.6)"
  description "Repeatability errors (E_R) calculation across four test temperatures"
  conformance_process conf_metrological_tests_measurement_error_repeatability_mdlo
  field conversion_factor_f : number { label "Conversion factor (f)" unit "counts/v" required true measurement_method computed calculation conversionFactor }
  field reference_indication_75pct : number { label "Reference indication at 75%" unit "counts" required true measurement_method direct }
  field indication_at_dmin : number { label "Indication at D_min" unit "counts" required true measurement_method direct }
  field n_lc : integer { label "Number of verification intervals (n_LC)" required true measurement_method declared }
  field plc : number { label "Apportionment factor (p_LC)" measurement_method declared default 0.7 }
  field temperature_series : array {
    items {
      type object
      fields {
        field temperature : number { label "Temperature" unit "degC" required true measurement_method direct }
        field test_loads : array {
          items {
            type object
            fields {
              field test_load : number { label "Test load" unit "g, kg, or t" required true measurement_method direct }
              field runs : array {
                items {
                  type object
                  fields {
                    field run_number : integer { label "Run number" required true measurement_method declared }
                    field indication : number { label "Indication (counts)" unit "counts" required true measurement_method direct }
                  }
                }
              }
              field repeatability_error_v : number { label "Repeatability error (E_R)" unit "v" measurement_method derived calculation repeatabilityError }
              field mpe : number { label "MPE" unit "v" measurement_method lookup calculation mpe }
              field within_mpe : enum { label "Within MPE" measurement_method evaluated }
            }
          }
        }
      }
    }
  }
  field overall_result : enum { label "Overall result" required true measurement_method evaluated values [pass, fail] }
  pass_fail {
    criteria "All E_R <= |MPE| for every test load at every temperature"
    pass_if "ocl{every(within_mpe) = yes}"
  }
}

form SampleSelection {
  name "SampleSelection (r60-3/sec-4.7)"
  description "Selection of sample(s) tested"
  field test_pattern : array {
    items {
      type object
      fields {
        field model_designation : string { label "Model Designation" required true }
        field serial_number : string { label "Serial Number" required true }
        field emax : number { label "Emax" unit "g, kg, or t" }
        field nlc : integer { label "Nlc" }
        field vmin : number { label "Vmin" unit "g, kg, or t" }
        field DR : number { label "DR" unit "g, kg, or t" }
      }
    }
  }
  field justification : array {
    items {
      type object
      fields {
        field model_designation : string { label "Model Designation" }
        field serial_number : string { label "Serial Number" }
        field justification_remark : string { label "Justification Remark" }
        field test_report_no : string { label "Test Report No" }
      }
    }
  }
}

form ShortTimePower {
  name "ShortTimePower (r60-3/form-6.13)"
  description "Short-time power reductions test"
  conformance_process conf_electronic_tests_short_time_power
  field conversion_factor_f : number { label "Conversion Factor F" unit "counts/v" required true }
  field dmin_value : number { label "Dmin Value" unit "g, kg, or t" }
  field reference_voltage_range : number { label "Reference Voltage Range" unit "V" required true }
  field disturbance_tests : array {
    items {
      type object
      fields {
        field test_load : number { label "Test Load" unit "g, kg, or t" }
        field amplitude_pct : number { label "Amplitude Pct" unit "%" }
        field duration_cycles : number { label "Duration Cycles" unit "cycles" }
        field number_of_disturbances : integer { label "Number Of Disturbances" }
        field indication_without : number { label "Indication Without" unit "counts" }
        field indication_with : number { label "Indication With" unit "counts" }
        field difference : number { label "Difference" unit "v" calculation ocl{(indication_with - indication_without) / conversion_factor_f} }
        field repetition_interval_v : number { label "Repetition Interval V" unit "v" }
        field significant_fault : enum { label "Significant Fault" values [no, yes] calculation ocl{if abs(difference) > vmin then 'yes' else 'no' endif} }
        field remarks : string { label "Remarks" }
      }
    }
  }
  field equipment_used : text { label "Equipment Used" }
  field remarks : text { label "Remarks" }
  field overall_result : enum { label "Overall Result" required true values [pass, fail] }
  pass_fail {
    criteria "No significant fault (> v_min) or fault detected and acted upon"
    pass_if "ocl{every(significant_fault) = 'no'}"
  }
}

form SoftwareExamination {
  name "SoftwareExamination (r60-3/sec-5.3)"
  description "Software examination (R 60-1, 6.1)"
  conformance_process conf_examinations_software
  field date : date { label "Date of examination" required true }
  field observer : string { label "Observer" }
  field serial_number : string { label "Serial number" required true }
  field software_version : string { label "Software version" }
  field identification_code : string { label "Identification code" }
  field software_sealed : enum { label "Software sealed" }
  field auto_change_identification_code : enum { label "Auto-change identification code" }
  field fixed_version_number : enum { label "Fixed version number" }
  field remarks : text { label "Remarks" }
  field overall_result : enum { label "Overall result" required true values [pass, fail] }
  pass_fail {
    criteria ""
    pass_if "ocl{software_sealed = yes and auto_change_identification_code = yes and fixed_version_number = yes}"
  }
}

form SpanStability {
  name "SpanStability (r60-3/form-6.19)"
  description "Span stability test measurement data"
  conformance_process conf_electronic_tests_span_stability
  applicability {
    accuracy_class: [B, C, D]
    runs_per_measurement: { B: 5 C: 3 D: 3 }
  }
  field conversion_factor_f : number { label "Conversion Factor F" unit "counts/v" required true measurement_method computed }
  field dmin_value : number { label "Minimum Test Load (D_min)" unit "g, kg, or t" measurement_method declared }
  field dmax_value : number { label "Maximum Test Load (D_max)" unit "g, kg, or t" measurement_method declared }
  field measurements : array {
    items {
      type object
      fields {
        field measurement_no : integer { label "Measurement No" required true measurement_method declared }
        field readings : object {
          field dmin : array {
            items {
              type object
              fields {
                field indication : number { label "Indication" unit "counts" measurement_method direct }
                field time : string { label "Time" measurement_method direct }
              }
            }
          }
          field dmax : array {
            items {
              type object
              fields {
                field indication : number { label "Indication" unit "counts" measurement_method direct }
                field time : string { label "Time" measurement_method direct }
              }
            }
          }
        }
        field avg_dmin : number { label "Average D_min Indication" unit "counts" measurement_method derived derivation "ocl{mean(readings.dmin->collect(r | r.indication))}" }
        field avg_dmax : number { label "Average D_max Indication" unit "counts" measurement_method derived derivation "ocl{mean(readings.dmax->collect(r | r.indication))}" }
        field span : number { label "Span" unit "counts" measurement_method derived derivation "ocl{avg_dmax - avg_dmin}" }
        field span_vmin : number { label "Span (v_min)" unit "v_min" measurement_method derived derivation "ocl{span / conversion_factor_f}" }
        field variation : number { label "Variation from first (v_min)" unit "v_min" measurement_method derived derivation "ocl{abs(span_vmin - measurements[0].span_vmin)}" }
        field within_limit : enum { label "Within limit" measurement_method evaluated }
        field evaluator : string { label "Evaluator" measurement_method declared }
        field remarks : text { label "Remarks" measurement_method declared }
        field conditions : object {
          field date : date { label "Date" measurement_method direct }
          field time : string { label "Time" measurement_method direct }
          field temperature : number { label "Temperature" unit "degC" measurement_method direct }
          field relative_humidity : number { label "Relative Humidity" unit "%" measurement_method direct }
          field barometric_pressure : number { label "Barometric Pressure" unit "kPa" measurement_method direct }
        }
      }
    }
  }
  field max_allowable_variation : number { label "Maximum Allowable Variation" unit "v_min" measurement_method computed derivation "ocl{max(0.5, lookup_mpe(dmax_value, accuracy_class, plc) * 0.5)}" }
  field overall_result : enum { label "Overall Result" required true measurement_method evaluated values [pass, fail] }
  pass_fail {
    criteria "Span variation between any two measurements must not exceed max(0.5 v_min, 0.5 * |MPE|) per R 60-1, 5.7.2.6"
    pass_if "ocl{measurements->forAll(m | m.within_limit = 'yes')}"
  }
}

form SuitabilityExamination {
  name "SuitabilityExamination (r60-3/sec-5.2)"
  description "Suitability for testing examination"
  conformance_process conf_examinations_suitability
  field date : date { label "Date of examination" required true }
  field observer : string { label "Observer" }
  field serial_number : string { label "Serial number" required true }
  field suitability_items : array {
    items {
      type object
      fields {
        field item : string { label "Item" }
        field fulfils_requirements : enum { label "Fulfils requirements" }
      }
    }
  }
  field remarks : text { label "Remarks" }
  field overall_result : enum { label "Overall result" required true values [pass, fail] }
  pass_fail {
    criteria ""
    pass_if "ocl{overall_result = 'pass'}"
  }
}

