form WarmUpTime {
  name "WarmUpTime (r60-3/form-6.11)"
  description "Warm-up time test for electronic load cells"
  conformance_process conf_electronic_tests_warm_up_time
  field conversion_factor_f : number { label "Conversion Factor F" unit "counts/v" required true }
  field duration_of_disconnection : string { label "Duration Of Disconnection" required true }
  field readings : object {
    field initial_dmin : object {
      field indication : number { label "Indication" unit "counts" }
      field time : string { label "Time" }
    }
    field initial_dmax : object {
      field indication : number { label "Indication" unit "counts" }
      field time : string { label "Time" }
    }
    field initial_span_counts : number { label "Initial Span Counts" unit "counts" calculation ocl{initial_dmax.indication - initial_dmin.indication} }
    field initial_span_vmin : number { label "Initial Span Vmin" unit "v_min" calculation ocl{initial_span_counts / conversion_factor_f} }
    field after_5min_dmin : object {
      field indication : number { label "Indication" }
      field time : string { label "Time" }
    }
    field after_5min_dmax : object {
      field indication : number { label "Indication" }
      field time : string { label "Time" }
    }
    field after_5min_span_counts : number { label "After 5min Span Counts" calculation ocl{after_5min_dmax.indication - after_5min_dmin.indication} }
    field after_5min_span_vmin : number { label "After 5min Span Vmin" calculation ocl{after_5min_span_counts / conversion_factor_f} }
    field after_5min_change : number { label "After 5min Change" calculation ocl{after_5min_span_vmin - initial_span_vmin} }
    field after_15min_dmin : object {
      field indication : number { label "Indication" }
      field time : string { label "Time" }
    }
    field after_15min_dmax : object {
      field indication : number { label "Indication" }
      field time : string { label "Time" }
    }
    field after_15min_span_counts : number { label "After 15min Span Counts" calculation ocl{after_15min_dmax.indication - after_15min_dmin.indication} }
    field after_15min_span_vmin : number { label "After 15min Span Vmin" calculation ocl{after_15min_span_counts / conversion_factor_f} }
    field after_15min_change : number { label "After 15min Change" calculation ocl{after_15min_span_vmin - initial_span_vmin} }
    field after_30min_dmin : object {
      field indication : number { label "Indication" }
      field time : string { label "Time" }
    }
    field after_30min_dmax : object {
      field indication : number { label "Indication" }
      field time : string { label "Time" }
    }
    field after_30min_span_counts : number { label "After 30min Span Counts" calculation ocl{after_30min_dmax.indication - after_30min_dmin.indication} }
    field after_30min_span_vmin : number { label "After 30min Span Vmin" calculation ocl{after_30min_span_counts / conversion_factor_f} }
    field after_30min_change : number { label "After 30min Change" calculation ocl{after_30min_span_vmin - initial_span_vmin} }
    field mpc : number { label "Mpc" unit "v_min" calculation ocl{abs(lookup_mpe(dmax, accuracy_class, plc))} }
  }
  field overall_result : enum { label "Overall Result" required true values [pass, fail] }
  pass_fail {
    criteria "Change of span must not exceed v_min"
    pass_if "ocl{max(after_5min_change, after_15min_change, after_30min_change) <= mpc}"
  }
}

