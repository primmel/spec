form Surge {
  name "Surge (r60-3/form-6.15)"
  description "Surge test"
  conformance_process conf_electronic_tests_surge
  field conversion_factor_f : number { label "Conversion Factor F" unit "counts/v" required true }
  field dmin_value : number { label "Dmin Value" }
  field unit : enum { label "Unit" values [g, kg, t] }
  field test_conditions : object {
    field output_gained_method : enum { label "Output Gained Method" values [actual_loads, simulating_loading] }
    field simulating_using : string { label "Simulating Using" }
    field cable_type : enum { label "Cable Type" values [symmetrical, unsymmetrical] }
    field line_to_line_kv : number { label "Line To Line Kv" unit "kV" }
    field line_to_earth_kv : number { label "Line To Earth Kv" unit "kV" }
    field test_load_value : number { label "Test Load Value" }
  }
  field test_cycles : array {
    items {
      type object
      fields {
        field cycle_phase : enum { label "Cycle Phase" values [initial, during_exposure, after] }
        field load : number { label "Load" }
        field time_start : string { label "Time Start" }
        field time_stop : string { label "Time Stop" }
        field reference : number { label "Reference" }
        field indicated : number { label "Indicated" }
        field error : number { label "Error" unit "v_min" }
        field relative_error_pct : number { label "Relative Error Pct" unit "%" }
        field mpe_pct : number { label "Mpe Pct" unit "%" }
      }
    }
  }
  field observed_faults : array {
    items {
      type object
      fields {
        field fault_type : enum { label "Fault Type" values [line_to_line_up, line_to_line_down, line_to_earth_up, line_to_earth_down] }
        field fault_limit_pct : number { label "Fault Limit Pct" unit "%" }
        field fault_deviation : string { label "Fault Deviation" }
        field significant : enum { label "Significant" values [yes, no] }
        field acts_on_fault : enum { label "Acts On Fault" values [yes, no] }
      }
    }
  }
  field observations : text { label "Observations" }
  field overall_result : enum { label "Overall Result" required true values [pass, fail] }
  pass_fail {
    criteria "No significant fault or fault detected and acted upon"
    pass_if "ocl{every(significant) = no or every(acts_on_fault) = yes}"
  }
}

