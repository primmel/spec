form TemperatureMDLO {
  name "TemperatureMDLO (r60-3/table-6.7)"
  description "Temperature effects on minimum dead load output (C_M)"
  conformance_process conf_metrological_tests_measurement_error_repeatability_mdlo
  field conversion_factor_f : number { label "Conversion factor (f)" unit "counts/v" required true measurement_method computed calculation conversionFactor }
  field reference_indication_75pct : number { label "Reference indication at 75%" unit "counts" required true measurement_method direct }
  field indication_at_dmin : number { label "Indication at D_min" unit "counts" required true measurement_method direct }
  field n_lc : integer { label "Number of verification intervals (n_LC)" required true measurement_method declared }
  field plc : number { label "Apportionment factor (p_LC)" measurement_method declared default 0.7 }
  field temperature_readings : array {
    items {
      type object
      fields {
        field temperature : number { label "Temperature" unit "degC" required true measurement_method direct }
        field indication : number { label "Indication" unit "counts" required true measurement_method direct }
        field change_v : number { label "Change (v)" unit "v" measurement_method derived derivation "ocl{if $index = 0 then 0 else (indication - $prev.indication) / conversion_factor_f endif}" }
        field change_per_5deg : number { label "Change per 5 degC" unit "v" measurement_method derived derivation "ocl{if $index = 0 then 0 else change_v * 5 / abs(temperature - $prev.temperature) endif}" }
        field mpc : number { label "MPC" unit "v" measurement_method declared derivation "ocl{$context.p_LC}" }
        field within_mpc : enum { label "Within MPC" measurement_method evaluated }
      }
    }
  }
  field overall_result : enum { label "Overall result" required true measurement_method evaluated values [pass, fail] }
  pass_fail {
    criteria "C_M(v) per 5 degC <= p_LC for classes B/C/D; per 2 degC for class A"
    pass_if "ocl{temperature_readings->forAll(r | r.within_mpc = 'yes')}"
  }
}

