reference R60-2-2-10-7-6 { document "OIML R 60-2:2021" clause "2.10.7.6" title "ESD test" }
reference R60-2-2-10-7-7 { document "OIML R 60-2:2021" clause "2.10.7.7" title "EMC susceptibility test" }
reference R60-2-2-10-7-8 { document "OIML R 60-2:2021" clause "2.10.7.8" title "Conducted EMC test" }
reference R60-2-2-10-8 { document "OIML R 60-2:2021" clause "2.10.8" title "Span stability test" }

// R 60-3 references (forms and tables)
reference R60-3-2-1-2-2 { document "OIML R 60-3:2021" clause "2.1.2.2" title "Load cell error (E_L) calculation" }
reference R60-3-2-1-2-4 { document "OIML R 60-3:2021" clause "2.1.2.4" title "Conversion factor (f)" }
reference R60-3-2-1-2-6 { document "OIML R 60-3:2021" clause "2.1.2.6" title "Reference indication" }
reference R60-3-2-1-3 { document "OIML R 60-3:2021" clause "2.1.3" title "Repeatability error calculation" }
reference R60-3-2-1-4 { document "OIML R 60-3:2021" clause "2.1.4" title "Temperature effect on MDLO (C_M)" }
reference R60-3-2-1-5 { document "OIML R 60-3:2021" clause "2.1.5" title "Creep (C_C) and DR (C_DR)" }
reference R60-3-2-1-7 { document "OIML R 60-3:2021" clause "2.1.7" title "Humidity effects (C_Hmin, C_Hmax)" }
reference R60-3-4 { document "OIML R 60-3:2021" clause "4" title "Evaluation report metadata" }
reference R60-3-5 { document "OIML R 60-3:2021" clause "5" title "Examination" }
reference R60-3-6 { document "OIML R 60-3:2021" clause "6" title "Performance tests" }

// Annex references
reference R60-A-A { document "OIML R 60 Annex A-A" clause "A-A" title "Definitions from other publications" }
reference R60-A-B { document "OIML R 60 Annex A-B" clause "A-B" title "Certificate content (page 1)" }
reference R60-A-C { document "OIML R 60 Annex A-C" clause "A-C" title "Certificate content (page 2 — per-load-cell)" }
reference R60-A-D { document "OIML R 60 Annex A-D" clause "A-D" title "Selection of load cells for testing — practical example" }
reference R60-A-E { document "OIML R 60 Annex A-E" clause "A-E" title "Load transmission" }

// External standard references (Annex A-A)
reference OIML-D-11 { document "OIML D 11:2004" clause "general" title "General requirements for electronic measuring instruments" }
reference OIML-D-31 { document "OIML D 31" clause "general" title "General requirements for computer-controlled measuring instruments" }
reference OIML-R-76 { document "OIML R 76:2006" clause "T.2.2.7" title "Non-automatic weighing instruments — weighing module" }

// ─────────────────────────────────────────────────────────────────────
// Symbols — formal symbol registry (R 60-3 + Annex)
// ─────────────────────────────────────────────────────────────────────

// Metrological symbols
symbol f {
  name "Conversion factor"
  type number
  unit "counts/v"
  latex "f"
  reference { R60-3-2-1-2-4 }
}

symbol nLC {
  name "Maximum number of load cell verification intervals"
  type integer
  unit "1"
  latex "n_{LC}"
  reference { R60-1-3-5-8 }
}

symbol Emax {
  name "Maximum capacity"
  type number
  unit "kg"
  latex "E_{max}"
  reference { R60-1-3-3 }
}

symbol Emin {
  name "Minimum dead load"
  type number
  unit "kg"
  latex "E_{min}"
}

symbol pLC {
  name "Apportioning factor"
  type number
  unit "1"
  latex "p_{LC}"
  reference { R60-1-3-7-2 }
}

symbol vmin {
  name "Minimum verification interval"
  type number
  unit "kg"
  latex "v_{min}"
}

symbol Y {
  name "Ratio of min verification interval (Emax / vmin)"
  type integer
  unit "1"
  latex "Y"
}

symbol Z {
  name "Ratio of min DR"
  type integer
  unit "1"
  latex "Z"
}

symbol DR {
  name "Dead load output return"
  type number
  unit "% RO"
  latex "DR"
}

symbol MPE {
  name "Maximum permissible error"
  type number
  unit "v"
  latex "MPE"
  reference { R60-1-5-3-2 }
}

symbol EL {
  name "Load cell error"
  type number
  unit "v"
  latex "E_L"
  reference { R60-3-2-1-2-2 }
}

symbol ER {
  name "Repeatability error"
  type number
  unit "v"
  latex "E_R"
  reference { R60-3-2-1-3 }
}

symbol CC {
  name "Creep"
  type number
  unit "v"
  latex "C_C"
  reference { R60-1-5-5-1 }
}

symbol CDR {
  name "Dead load output return value"
  type number
  unit "v"
  latex "C_{DR}"
  reference { R60-1-5-5-2 }
}

symbol CM {
  name "Temperature effect on minimum dead load output"
  type number
  unit "v"
  latex "C_M"
  reference { R60-3-2-1-4 }
}

symbol CHmin {
  name "Humidity effect on minimum test load indication"
  type number
  unit "v"
  latex "C_{Hmin}"
  reference { R60-1-5-6-3-1 }
}

symbol CHmax {
  name "Humidity effect on span"
  type number
  unit "v"
  latex "C_{Hmax}"
  reference { R60-1-5-6-3 }
}

symbol Dmax {
  name "Maximum test load"
  type number
  unit "kg"
  latex "D_{max}"
}

symbol Dmin {
  name "Minimum test load"
  type number
  unit "kg"
  latex "D_{min}"
}

// ─────────────────────────────────────────────────────────────────────
// Calculations — OCL primitives
// ─────────────────────────────────────────────────────────────────────

calculation loadCellError {
  name "Load cell error"
  inputs {
    avgIndication : number { unit "counts" }
    referenceIndication : number { unit "counts" }
    conversionFactor : number { unit "counts/v" }
  }
  output : number { unit "v" }
  expression "ocl{(avgIndication - referenceIndication) / conversionFactor}"
  reference { R60-3-2-1-2-2 }
}

calculation referenceIndication {
  name "Reference indication (R_i)"
  inputs {
    testLoad : number { unit "kg" }
    dMin : number { unit "kg" }
    dMax : number { unit "kg" }
    n : integer { unit "1" }
    f : number { unit "counts/v" }
  }
  output : number { unit "counts" }
  expression "ocl{(testLoad - dMin) / (dMax - dMin) * n * f}"
  reference { R60-3-2-1-2-6 }
}

calculation conversionFactor {
  name "Conversion factor (f)"
  inputs {
    avgIndicationAt75pct : number { unit "counts" }
    indicationAtDmin : number { unit "counts" }
    n_LC : integer { unit "1" }
  }
  output : number { unit "counts/v" }
  expression "ocl{(avgIndicationAt75pct - indicationAtDmin) / (0.75 * n_LC)}"
  reference { R60-3-2-1-2-4 }
}

calculation repeatabilityError {
  name "Repeatability error"
  inputs {
    values : list<number> { unit "counts" }
  }
  output : number { unit "counts" }
  expression "ocl{values->max() - values->min()}"
  reference { R60-3-2-1-3 }
}

calculation mean {
  name "Arithmetic mean"
  inputs {
    values : list<number> { unit "1" }
  }
  output : number { unit "1" }
  expression "ocl{values->sum() / values->size()}"
}

calculation creep {
  name "Creep error"
  inputs {
    indicationAtTime : number { unit "counts" }
    initialIndication : number { unit "counts" }
    conversionFactor : number { unit "counts/v" }
  }
  output : number { unit "v" }
  expression "ocl{(indicationAtTime - initialIndication) / conversionFactor}"
  reference { R60-1-5-5-1 }
}

calculation deadLoadOutputReturn {
  name "Dead load output return (DR)"
  inputs {
    minLoadIndication2 : number { unit "counts" }
    minLoadIndication1 : number { unit "counts" }
    conversionFactor : number { unit "counts/v" }
  }
  output : number { unit "v" }
  expression "ocl{(minLoadIndication2 - minLoadIndication1) / conversionFactor}"
  reference { R60-1-5-5-2 }
}

calculation humidityCHmin {
  name "C_Hmin (humidity effect on MDLO)"
  inputs {
    indDminAfter : number { unit "counts" }
    indDminBefore : number { unit "counts" }
    conversionFactor : number { unit "counts/v" }
  }
  output : number { unit "v" }
  expression "ocl{(indDminAfter - indDminBefore) / conversionFactor}"
  reference { R60-3-2-1-7 }
}

calculation humidityCHmax {
  name "C_Hmax (humidity effect on span)"
  inputs {
    avgDmaxAfter : number { unit "counts" }
    avgDminAfter : number { unit "counts" }
    avgDmaxBefore : number { unit "counts" }
    avgDminBefore : number { unit "counts" }
    conversionFactor : number { unit "counts/v" }
  }
  output : number { unit "v" }
  expression "ocl{((avgDmaxAfter - avgDminAfter) - (avgDmaxBefore - avgDminBefore)) / conversionFactor}"
  reference { R60-3-2-1-7 }
}

// ─────────────────────────────────────────────────────────────────────
// Provisions — R 60-1 requirements
// ─────────────────────────────────────────────────────────────────────

// ── Classification (R 60-1 §5.1) ─────────────────────────────────────

provision AccuracyClasses {
  condition "Load cells shall be ranked into one of the four accuracy classes: A, B, C, D."
  modality SHALL
  reference { R60-1-5-1-1 }
}

provision MaxVerificationIntervals {
  condition "The maximum number of load cell verification intervals (nLC) shall be within the limits presented in R 60-1 Table 1."
  modality SHALL
  reference { R60-1-5-1-2 }
}

provision MinVerificationInterval {
  condition "The minimum load cell verification interval (v_min) shall be specified by the manufacturer."
  modality SHALL
  reference { R60-1-5-1-3 }
}

provision SupplementaryLoading {
  condition "Load cells shall be classified by the intended manner of load application where there would be a risk of confusing loading type."
  modality SHALL
  reference { R60-1-5-1-4 }
}

provision CompleteClassification {
  condition "The load cell shall be classified per the six parameters: accuracy class, nLC, load application, working temperature, humidity symbol, and additional characterisation."
  modality SHALL
  reference { R60-1-5-1-5 }
}

provision StandardClassification {
  condition "Standard classifications shall be used."
  modality SHALL
  reference { R60-1-5-1-6 }
}

provision MultipleClassifications {
  condition "A load cell may bear multiple classifications according to the intended manner of load application."
  modality MAY
  reference { R60-1-5-1-7 }
}

// ── Measuring range (R 60-1 §5.2) ───────────────────────────────────

provision MeasuringRangeMin {
  condition "The smallest load applied during test shall not be less than E_min."
  modality SHALL
  reference { R60-1-5-2 }
}

provision MeasuringRangeMax {
  condition "The largest load applied during test shall not be greater than E_max."
  modality SHALL
  reference { R60-1-5-2 }
}

// ── MPE (R 60-1 §5.3) ───────────────────────────────────────────────

provision MPEPerClass {
  condition "The MPE values for each accuracy class shall be as tabulated in R 60-1 Table 4."
  modality SHALL
  reference { R60-1-5-3-1 }
}

provision MPETypeEvaluation {
  condition "The MPE on type evaluation shall be derived as p_LC × 0.5 v (first tier), p_LC × 1.0 v (second tier), p_LC × 1.5 v (third tier)."
  modality SHALL
  reference { R60-1-5-3-2 }
}

// ── Repeatability (R 60-1 §5.4) ─────────────────────────────────────

provision RepeatabilityError {
  condition "The repeatability error at any test load shall not exceed the absolute value of MPE at that load."
  modality SHALL
  reference { R60-1-5-4 }
}

// ── Creep + DR (R 60-1 §5.5) ────────────────────────────────────────

provision Creep30Min {
  condition "The creep change over 30 minutes shall not exceed 0.7 × |MPE| at D_max."
  modality SHALL
  reference { R60-1-5-5-1 }
}

provision Creep20To30Min {
  condition "The creep change between 20 and 30 minutes shall not exceed 0.15 × |MPE| at D_max."
  modality SHALL
  reference { R60-1-5-5-1 }
}

provision DRHalfV {
  condition "The dead load output return shall not exceed 0.5 v."
  modality SHALL
  reference { R60-1-5-5-2 }
}

// ── Influence quantities (R 60-1 §5.6) ──────────────────────────────

provision TemperatureLimits {
  condition "The load cell shall meet the requirements within the temperature limits specified by the manufacturer (-10°C to +40°C if not specified)."
  modality SHALL
  reference { R60-1-5-6-1-1 }
}

provision SpecialTemperatureLimits {
  condition "Special limits of working temperature may be specified; if so, they shall be marked on the load cell."
  modality MAY
  reference { R60-1-5-6-1-2 }
}

provision TemperatureEffectMDLO {
  condition "The temperature effect on minimum dead load output shall not exceed p_LC × v_min per 5°C."
  modality SHALL
  reference { R60-1-5-6-1-3 }
}

provision BarometricPressure {
  condition "The change in indication due to a change in barometric pressure shall not exceed the prescribed limits."
  modality SHALL
  reference { R60-1-5-6-2 }
}

provision HumidityCH {
  condition "For CH or unmarked load cells, the humidity effect on MDLO (C_Hmin) shall not exceed 4% × n_LC and the humidity effect on span (C_Hmax) shall not exceed |MPE|."
  modality SHALL
  reference { R60-1-5-6-3-1 }
}

provision HumiditySH {
  condition "For SH load cells, the humidity effect on span shall not exceed the prescribed limits after damp heat steady-state test."
  modality SHALL
  reference { R60-1-5-6-3-2 }
}

// ── Electronic (R 60-1 §5.7) ────────────────────────────────────────

provision WarmUpTime {
  condition "After warm-up, the load cell indication shall be within ±0.5 v of the steady-state indication."
  modality SHALL
  reference { R60-1-5-7-2-1 }
}

provision PowerVoltageVariation {
  condition "Variations in power voltage shall not cause a change in indication exceeding ±0.5 v (or significant fault threshold)."
  modality SHALL
  reference { R60-1-5-7-2-2 }
}

provision ShortTimePowerReductions {
  condition "Short-time power reductions shall not cause significant faults."
  modality SHALL
  reference { R60-1-5-7-2-3 }
}

provision Bursts {
  condition "Bursts (electrical fast transients) shall not cause significant faults."
  modality SHALL
  reference { R60-1-5-7-2-4 }
}

provision Surge {
  condition "Surge shall not cause significant faults."
  modality SHALL
  reference { R60-1-5-7-2-5 }
}

provision ESD {
  condition "Electrostatic discharge shall not cause significant faults."
  modality SHALL
  reference { R60-1-5-7-2-6 }
}

provision EMCSusceptibility {
  condition "Exposure to radiated RF EM fields shall not cause significant faults."
  modality SHALL
  reference { R60-1-5-7-2-7 }
}

provision ConductedEMC {
  condition "Exposure to conducted RF EM fields shall not cause significant faults."
  modality SHALL
  reference { R60-1-5-7-2-8 }
}

provision SpanStability {
  condition "The span shall not drift more than the prescribed limit over the duration of the span stability test."
  modality SHALL
  reference { R60-1-5-7-3 }
}

// ── Technical (R 60-1 §6) ───────────────────────────────────────────

provision Software {
  condition "Embedded software that influences the raw count output of the load cell shall be evaluated under the terms of this Recommendation and OIML D 31."
  modality SHALL
  reference { R60-1-6-1 }
}

provision MandatoryMarkings {
  condition "The following mandatory markings shall be clearly and indelibly marked on the load cell: manufacturer identification, type designation, serial number, accuracy class, nLC, and marking of humidity class."
  modality SHALL
  reference { R60-1-6-2-1 }
}

provision MandatoryAdditionalInfo {
  condition "Mandatory additional information shall be marked either on the load cell or in an accompanying document."
  modality SHALL
  reference { R60-1-6-2-2 }
}

provision NonMandatoryInfo {
  condition "Non-mandatory additional information may be provided at the manufacturer's discretion."
  modality MAY
  reference { R60-1-6-2-3 }
}

provision ClassDesignation {
  condition "The accuracy class shall be marked per R 60-1 §6.2.4.1."
  modality SHALL
  reference { R60-1-6-2-4-1 }
}

provision LoadTypeDesignation {
  condition "The load type (compression, tension, beam, universal) shall be marked per R 60-1 §6.2.4.2."
  modality SHALL
  reference { R60-1-6-2-4-2 }
}

provision TemperatureDesignation {
  condition "Working temperature shall be marked per R 60-1 §6.2.4.3."
  modality SHALL
  reference { R60-1-6-2-4-3 }
}

provision HumidityDesignation {
  condition "Humidity symbols (CH, SH, NH) shall be marked per R 60-1 §6.2.4.4."
  modality SHALL
  reference { R60-1-6-2-4-4 }
}

provision NLCDdesignation {
  condition "The n_LC shall be marked per R 60-1 §6.2.4.5."
  modality SHALL
  reference { R60-1-6-2-4-5 }
}

// ─────────────────────────────────────────────────────────────────────
// Notes — Annex A-A external definitions
// ─────────────────────────────────────────────────────────────────────

note ExternalDefinitions {
  type NOTE
  message "This model imports terminology from OIML D 11 (electronic measuring instruments) and OIML R 76 (non-automatic weighing instruments) per R 60 Annex A-A. External definitions include: electronic measuring instrument, module, device, checking facility (P, I, N types), durability protection facility, test (performance, type), mains power, power converter, batteries, and weighing module."
  reference { R60-A-A OIML-D-11 OIML-R-76 }
}

note CertificateLayout {
  type NOTE
  message "The certificate layout (page 1 + page 2) is defined per R 60 Annex B and C. Page 1 contains the certificate header (issuer, certificate number, classification symbol). Page 2 contains per-load-cell characteristics (Emax, nLC, Y, Z, p_LC, DR, rated output, input/output impedance, excitation, material, sealing)."
  reference { R60-A-B R60-A-C }
}

// ─────────────────────────────────────────────────────────────────────
// Processes — R 60-2 conformance tests
// ─────────────────────────────────────────────────────────────────────

// ── Examinations (R 60-2 §2.5–2.9) ──────────────────────────────────

process ExamineDocumentation {
  name "Documentation review"
  actor TestLaboratory
  modality SHALL
  validate_provision { Software }
  validate_measurement { "[documentation_completeness] = true" }
  output { FormInstanceRegistry }
  reference { R60-2-2-5 }
}

process ExamineMarkings {
  name "Marking examination"
  actor TestLaboratory
  modality SHALL
  validate_provision {
    MandatoryMarkings
    MandatoryAdditionalInfo
    ClassDesignation
    LoadTypeDesignation
    TemperatureDesignation
    HumidityDesignation
    NLCDdesignation
  }
  output { FormInstanceRegistry }
  reference { R60-2-2-5 }
}

process ExamineSuitability {
  name "Suitability for testing examination"
  actor TestLaboratory
  modality SHALL
  output { FormInstanceRegistry }
  reference { R60-2-2-3 }
}

process ExamineSoftware {
  name "Software examination"
  actor TestLaboratory
  modality SHALL
  validate_provision { Software }
  output { FormInstanceRegistry }
  reference { R60-2-2-5 }
}

// ── Performance tests — metrological (R 60-2 §2.10.1–2.10.6) ────────

process DetermineMeasurementError {
  name "Determination of measurement error, repeatability error, and temperature effect on MDLO"
  actor TestLaboratory
  modality SHALL
  validate_provision {
    MeasuringRangeMin
    MeasuringRangeMax
    MPETypeEvaluation
    RepeatabilityError
    TemperatureEffectMDLO
  }
  validate_measurement {
    "[EL] <= [MPE]"
    "[ER] <= [MPE]"
  }
  output { TestReportRegistry FormInstanceRegistry }
  reference_data_registry { TestRequestRegistry }
  reference { R60-2-2-10-1 R60-3-2-1-2-2 }
}

process DetermineCreep {
  name "Determination of creep error"
  actor TestLaboratory
  modality SHALL
  validate_provision { Creep30Min Creep20To30Min }
  validate_measurement {
    "[CC] <= 0.7 * [MPE]"
    "abs([CC_30min] - [CC_20min]) <= 0.15 * [MPE]"
  }
  output { TestReportRegistry FormInstanceRegistry }
  reference { R60-2-2-10-2 }
}

process DetermineDR {
  name "Determination of minimum dead load output return (DR)"
  actor TestLaboratory
  modality SHALL
  validate_provision { DRHalfV }
  validate_measurement { "[CDR] <= 0.5" }
  output { TestReportRegistry FormInstanceRegistry }
  reference { R60-2-2-10-3 }
}

process DetermineBarometricPressure {
  name "Determination of barometric pressure effects"
  actor TestLaboratory
  modality SHALL
  validate_provision { BarometricPressure }
  output { TestReportRegistry FormInstanceRegistry }
  reference { R60-2-2-10-4 }
}

process DetermineHumidityCH {
  name "Determination of humidity effects for CH/unmarked load cells"
  actor TestLaboratory
  modality SHALL
  validate_provision { HumidityCH }
  validate_measurement {
    "[CHmin] <= 0.04 * [nLC]"
    "[CHmax] <= [MPE]"
  }
  output { TestReportRegistry FormInstanceRegistry }
  reference { R60-2-2-10-5 R60-3-2-1-7 }
}

process DetermineHumiditySH {
  name "Determination of humidity effects for SH marked load cells"
  actor TestLaboratory
  modality SHALL
  validate_provision { HumiditySH }
  output { TestReportRegistry FormInstanceRegistry }
  reference { R60-2-2-10-6 }
}

// ── Performance tests — electronic (R 60-2 §2.10.7–2.10.8) ──────────

process TestWarmUpTime {
  name "Warm-up time test"
  actor TestLaboratory
  modality SHALL
  validate_provision { WarmUpTime }
  output { TestReportRegistry FormInstanceRegistry }
  reference { R60-2-2-10-7-1 }
}

process TestPowerVoltage {
  name "Power voltage variation test"
  actor TestLaboratory
  modality SHALL
  validate_provision { PowerVoltageVariation }
  output { TestReportRegistry FormInstanceRegistry }
  reference { R60-2-2-10-7-2 }
}

process TestShortTimePowerReductions {
  name "Short-time power reductions test"
  actor TestLaboratory
  modality SHALL
  validate_provision { ShortTimePowerReductions }
  output { TestReportRegistry FormInstanceRegistry }
  reference { R60-2-2-10-7-3 }
}

process TestBursts {
  name "Bursts (electrical fast transients) test"
  actor TestLaboratory
  modality SHALL
  validate_provision { Bursts }
  output { TestReportRegistry FormInstanceRegistry }
  reference { R60-2-2-10-7-4 }
}

process TestSurge {
  name "Surge test"
  actor TestLaboratory
  modality SHALL
  validate_provision { Surge }
  output { TestReportRegistry FormInstanceRegistry }
  reference { R60-2-2-10-7-5 }
}

process TestESD {
  name "Electrostatic discharge test"
  actor TestLaboratory
  modality SHALL
  validate_provision { ESD }
  output { TestReportRegistry FormInstanceRegistry }
  reference { R60-2-2-10-7-6 }
}

process TestEMCSusceptibility {
  name "Radiated RF electromagnetic field susceptibility test"
  actor TestLaboratory
  modality SHALL
  validate_provision { EMCSusceptibility }
  output { TestReportRegistry FormInstanceRegistry }
  reference { R60-2-2-10-7-7 }
}

process TestConductedEMC {
  name "Conducted (common mode) RF electromagnetic field test"
  actor TestLaboratory
  modality SHALL
  validate_provision { ConductedEMC }
  output { TestReportRegistry FormInstanceRegistry }
  reference { R60-2-2-10-7-8 }
}

process TestSpanStability {
  name "Span stability test"
  actor TestLaboratory
  modality SHALL
  validate_provision { SpanStability }
  output { TestReportRegistry FormInstanceRegistry }
  reference { R60-2-2-10-8 }
}

// ─────────────────────────────────────────────────────────────────────
// IA evaluation processes
// ─────────────────────────────────────────────────────────────────────

process ReviewTestReportAdmissibility {
  name "Review TestReport admissibility (Level 1)"
  actor IssuingAuthority
  modality SHALL
  output { EvaluationReportRegistry }
  reference_data_registry { TestReportRegistry }
}

process SynthesizePerModel {
  name "Per-model technical synthesis across labs (Level 2)"
  actor IssuingAuthority
  modality SHALL
  output { EvaluationReportRegistry }
}

process IssueCertificate {
  name "Issue Certificate of Conformity if approved"
  actor IssuingAuthority
  modality SHALL
  output { CertificateRegistry }
  reference_data_registry { EvaluationReportRegistry }
}

approval BIMLRegistration {
  name "BIML registration of the certificate"
  actor IssuingAuthority
  modality SHALL
  approve_by BIML
  approval_record { CertificateRegistry }
}

// ─────────────────────────────────────────────────────────────────────
// Sample selection (Annex A-D)
// ─────────────────────────────────────────────────────────────────────

process SelectSamplesPerR60AnnexD {
  name "Sample selection per R 60 Annex D practical example"
  actor IssuingAuthority
  modality SHALL
  reference_data_registry { MeasuringInstrumentRegistry InstrumentModelGroupRegistry InstrumentSampleRegistry }
  reference { R60-A-D }
}

// ─────────────────────────────────────────────────────────────────────
// Workflow — 5-phase certification subprocess
// ─────────────────────────────────────────────────────────────────────

start_event ApplicationAccepted { }

end_event CertificateIssued { }

end_event ApplicationRejected { }

exclusive_gateway AdmissibilityPass {
  label "Are all submitted TestReports admissible?"
}

exclusive_gateway AllModelsPass {
  label "Do all models pass technical synthesis?"
}

subprocess R60CertificationFlow {
  elements {
    ApplicationAccepted { x 0 y 0 }
    ExamineDocumentation { x 0 y 100 }
    ExamineMarkings { x 200 y 100 }
    ExamineSuitability { x 400 y 100 }
    ExamineSoftware { x 600 y 100 }
    DetermineMeasurementError { x 0 y 250 }
    DetermineCreep { x 200 y 250 }
    DetermineDR { x 400 y 250 }
    DetermineBarometricPressure { x 600 y 250 }
    DetermineHumidityCH { x 800 y 250 }
    DetermineHumiditySH { x 1000 y 250 }
    TestWarmUpTime { x 0 y 400 }
    TestPowerVoltage { x 200 y 400 }
    TestShortTimePowerReductions { x 400 y 400 }
    TestBursts { x 600 y 400 }
    TestSurge { x 800 y 400 }
    TestESD { x 1000 y 400 }
    TestEMCSusceptibility { x 0 y 550 }
    TestConductedEMC { x 200 y 550 }
    TestSpanStability { x 400 y 550 }
    ReviewTestReportAdmissibility { x 600 y 700 }
    AdmissibilityPass { x 600 y 800 }
    SynthesizePerModel { x 600 y 900 }
    AllModelsPass { x 600 y 1000 }
    IssueCertificate { x 600 y 1100 }
    BIMLRegistration { x 600 y 1200 }
    CertificateIssued { x 600 y 1300 }
    ApplicationRejected { x 800 y 1300 }
  }
  process_flow {
    Edge1 { from ApplicationAccepted to ExamineDocumentation }
    Edge2 { from ApplicationAccepted to ExamineMarkings }
    Edge3 { from ApplicationAccepted to ExamineSuitability }
    Edge4 { from ApplicationAccepted to ExamineSoftware }
    Edge5 { from ExamineDocumentation to DetermineMeasurementError }
    Edge6 { from ExamineMarkings to DetermineCreep }
    Edge7 { from ExamineSuitability to DetermineDR }
    Edge8 { from ExamineSoftware to DetermineBarometricPressure }
    Edge9 { from DetermineMeasurementError to DetermineHumidityCH }
    Edge10 { from DetermineCreep to DetermineHumiditySH }
    Edge11 { from DetermineDR to TestWarmUpTime }
    Edge12 { from DetermineBarometricPressure to TestPowerVoltage }
    Edge13 { from DetermineHumidityCH to TestShortTimePowerReductions }
    Edge14 { from DetermineHumiditySH to TestBursts }
    Edge15 { from TestWarmUpTime to TestSurge }
    Edge16 { from TestPowerVoltage to TestESD }
    Edge17 { from TestShortTimePowerReductions to TestEMCSusceptibility }
    Edge18 { from TestBursts to TestConductedEMC }
    Edge19 { from TestSurge to TestSpanStability }
    Edge20 { from TestESD to ReviewTestReportAdmissibility }
    Edge21 { from TestEMCSusceptibility to ReviewTestReportAdmissibility }
    Edge22 { from TestConductedEMC to ReviewTestReportAdmissibility }
    Edge23 { from TestSpanStability to ReviewTestReportAdmissibility }
    Edge24 { from ReviewTestReportAdmissibility to AdmissibilityPass }
    Edge25 { from AdmissibilityPass to SynthesizePerModel label "yes" }
    Edge26 { from AdmissibilityPass to ApplicationRejected label "no" }
    Edge27 { from SynthesizePerModel to AllModelsPass }
    Edge28 { from AllModelsPass to IssueCertificate label "yes" }
    Edge29 { from AllModelsPass to ApplicationRejected label "no" }
    Edge30 { from IssueCertificate to BIMLRegistration }
    Edge31 { from BIMLRegistration to CertificateIssued }
  }
  data { }
}

// ─────────────────────────────────────────────────────────────────────
// Terminology — R 60-1 §3 (terms & definitions, condensed)
// ─────────────────────────────────────────────────────────────────────

// A subset of the ~30 terms defined in R 60-1 §3. Full terminology
// lives in the OIML SMART YAML at data/oiml-r60/terminology/.

// (Primmel's terminology construct is part of the spec's terminology
// part; the symbol registry above carries the formal symbols that
// would appear in the terminology section.)

// ─────────────────────────────────────────────────────────────────────
// State machines — entity lifecycles with declarative cascades
// ─────────────────────────────────────────────────────────────────────

state_machine Application {
  initial DRAFT

  states {
    DRAFT
    SUBMITTED
    SAMPLES_REQUESTED
    SAMPLES_RECEIVED
    UNDER_REVIEW
    ACCEPTED
    REJECTED
    WITHDRAWN
  }

  transition DRAFT -> SUBMITTED action applicant_submits {
  }

  transition SUBMITTED -> SAMPLES_REQUESTED action ia_requests_samples {
  }

  transition SAMPLES_REQUESTED -> SAMPLES_RECEIVED action ia_receives_samples {
    cascade InstrumentSample {
      where "applicationId = ${this.id}"
      set { status: "RECEIVED_BY_IA" }
    }
  }

  transition SAMPLES_RECEIVED -> UNDER_REVIEW action ia_starts_review {
  }

  transition UNDER_REVIEW -> ACCEPTED action ia_accepts {
    guard "documentation_complete = true"
    cascade TestRequest {
      where "applicationId = ${this.id}"
      set { status: "ISSUED" }
    }
  }

  transition UNDER_REVIEW -> REJECTED action ia_rejects {
    set { rejection_reason: "${this.rejection_reason}" }
  }

  transition * -> WITHDRAWN action applicant_withdraws {
  }
}

state_machine TestRequest {
  initial DRAFT

  states {
    DRAFT
    ISSUED
    ACCEPTED_BY_LAB
    IN_PROGRESS
    COMPLETED
    WITHDRAWN
    REJECTED_BY_LAB
  }

  transition DRAFT -> ISSUED action ia_issues {
    cascade TestAssignment {
      where "testRequestId = ${this.id}"
      set { status: "PENDING" }
    }
  }

  transition ISSUED -> ACCEPTED_BY_LAB action lab_accepts {
    cascade TestAssignment {
      where "testRequestId = ${this.id}"
      set { status: "ACCEPTED" }
    }
  }

  transition ACCEPTED_BY_LAB -> IN_PROGRESS action lab_starts {
    cascade TestAssignment {
      where "testRequestId = ${this.id} and status = 'ACCEPTED'"
      set { status: "IN_PROGRESS" }
    }
  }

  transition IN_PROGRESS -> COMPLETED action lab_issues_test_report {
    cascade TestReport {
      where "testRequestId = ${this.id}"
      set { status: "SUBMITTED" }
    }
    cascade TestAssignment {
      where "testRequestId = ${this.id} and status = 'IN_PROGRESS'"
      set { status: "COMPLETED" }
    }
    cascade FormInstance {
      where "testRequestId = ${this.id}"
      set { status: "LOCKED" }
    }
  }

  transition ISSUED -> REJECTED_BY_LAB action lab_rejects {
  }

  transition * -> WITHDRAWN action ia_withdraws {
    set { withdrawn_reason: "${this.withdrawn_reason}" }
  }
}

state_machine TestReport {
  initial DRAFT

  states {
    DRAFT
    SUBMITTED
    UNDER_REVIEW
    ACCEPTED
    REJECTED
  }

  transition DRAFT -> SUBMITTED action lab_submits {
    cascade FormInstance {
      where "testReportId = ${this.id}"
      set { status: "LOCKED" }
    }
    cascade TestRequest {
      where "id = ${this.testRequestId}"
      set { status: "COMPLETED" }
    }
  }

  transition SUBMITTED -> UNDER_REVIEW action ia_starts_review {
  }

  transition UNDER_REVIEW -> ACCEPTED action ia_accepts_report {
    guard "not some(FormInstance where testReportId = ${this.id} and result = 'FAIL')"
    cascade TestReportDetermination {
      where "testReportId = ${this.id}"
      set { decision: "ACCEPTED" }
    }
  }

  transition UNDER_REVIEW -> REJECTED action ia_rejects_report {
    guard "some(FormInstance where testReportId = ${this.id} and result = 'FAIL')"
    cascade TestReportDetermination {
      where "testReportId = ${this.id}"
      set { decision: "REJECTED" }
    }
  }
}

state_machine FormInstance {
  initial OPEN

  states {
    OPEN
    LOCKED
    ACCEPTED
    REJECTED
  }

  transition OPEN -> LOCKED action lab_submits_report {
  }

  transition LOCKED -> ACCEPTED action ia_accepts_report {
  }

  transition LOCKED -> REJECTED action ia_rejects_report {
  }
}

state_machine EvaluationReport {
  initial DRAFT

  states {
    DRAFT
    IN_PROGRESS
    FINALIZED
    AMENDED
  }

  transition DRAFT -> IN_PROGRESS action ia_starts_evaluation {
  }

  transition IN_PROGRESS -> FINALIZED action ia_finalizes {
    guard "every TestReport has a TestReportDetermination"
    cascade Certificate {
      where "evaluationReportId = ${this.id}"
      set { status: "PENDING_REGISTRATION" }
    }
  }

  transition FINALIZED -> AMENDED action ia_amends {
    cascade Certificate {
      where "evaluationReportId = ${this.id}"
      set { status: "UNDER_INVESTIGATION" }
    }
  }
}

state_machine Certificate {
  initial DRAFT

  states {
    DRAFT
    PENDING_REGISTRATION
    ACTIVE
    EXPIRED
    WITHDRAWN
    SUSPENDED
    UNDER_INVESTIGATION
  }

  transition DRAFT -> PENDING_REGISTRATION action ia_submits_for_registration {
  }

  transition PENDING_REGISTRATION -> ACTIVE action biml_registers {
  }

  transition ACTIVE -> EXPIRED action periodicity_elapsed {
  }

  transition ACTIVE -> WITHDRAWN action ia_withdraws {
    set { withdrawn_reason: "${this.withdrawn_reason}" }
  }

  transition ACTIVE -> SUSPENDED action ia_suspends {
  }

  transition SUSPENDED -> ACTIVE action ia_lifts_suspension {
  }

  transition ACTIVE -> UNDER_INVESTIGATION action biml_investigates {
  }

  transition UNDER_INVESTIGATION -> WITHDRAWN action investigation_concludes_negative {
  }
}

state_machine InstrumentSample {
  initial REQUESTED

  states {
    REQUESTED
    IN_TRANSIT_TO_IA
    RECEIVED_BY_IA
    IN_TRANSIT_TO_LAB
    AT_LAB
    IN_TESTING
    RETURNED_TO_IA
    RETURNED_TO_MANUFACTURER
    DISPOSED
  }

  transition REQUESTED -> IN_TRANSIT_TO_IA action manufacturer_dispatches {
    cascade CustodyEvent {
      where "id = NULL"
      set {
        sampleId: "${this.id}"
        fromParty: "${this.manufacturerId}"
        toParty: "${this.applicationId}_IA"
        timestamp: "${now}"
      }
    }
  }

  transition IN_TRANSIT_TO_IA -> RECEIVED_BY_IA action ia_receives {
    cascade CustodyEvent {
      where "id = NULL"
      set {
        sampleId: "${this.id}"
        toParty: "${this.applicationId}_IA"
        timestamp: "${now}"
      }
    }
  }

  transition RECEIVED_BY_IA -> IN_TRANSIT_TO_LAB action ia_dispatches_to_lab {
    cascade CustodyEvent {
      where "id = NULL"
      set { fromParty: "${this.applicationId}_IA" toParty: "${this.laboratoryId}" timestamp: "${now}" }
    }
  }

  transition IN_TRANSIT_TO_LAB -> AT_LAB action lab_receives {
    cascade CustodyEvent {
      where "id = NULL"
      set { toParty: "${this.laboratoryId}" timestamp: "${now}" }
    }
  }

  transition AT_LAB -> IN_TESTING action lab_starts_testing {
  }

  transition IN_TESTING -> AT_LAB action lab_ends_testing {
  }

  transition AT_LAB -> IN_TRANSIT_TO_IA action lab_returns_to_ia {
    cascade CustodyEvent {
      where "id = NULL"
      set { fromParty: "${this.laboratoryId}" timestamp: "${now}" }
    }
  }

  transition IN_TRANSIT_TO_IA -> RETURNED_TO_IA action ia_receives_back {
  }

  transition RETURNED_TO_IA -> RETURNED_TO_MANUFACTURER action ia_returns_to_manufacturer {
    cascade CustodyEvent {
      where "id = NULL"
      set { toParty: "${this.manufacturerId}" timestamp: "${now}" }
    }
  }

  transition RETURNED_TO_MANUFACTURER -> DISPOSED action manufacturer_disposes {
    cascade CustodyEvent {
      where "id = NULL"
      set { timestamp: "${now}" condition: "DISPOSED" }
    }
  }
}

// ─────────────────────────────────────────────────────────────────────
// Subforms — parameterized row shapes for TRFs (R 60-3)
// ─────────────────────────────────────────────────────────────────────

subform LoadTestRow {
  parameters {
    n_runs : integer {
      description "Number of runs per test_load. Resolved from accuracy_class."
      mapping {
        A: 5
        B: 5
        C: 3
        D: 3
      }
    }
  }

  type object
  description "One row of a load-test table: applied load + N runs of (indication, time) + computed aggregates."

  field test_load : number {
    label "Test load"
    unit "g, kg, or t"
    measurement_method direct
    required true
  }

  field runs : array {
    label "Runs"
    min_items "${{ n_runs }}"
    max_items "${{ n_runs }}"
    items {
      type object
      fields {
        field indication : number {
          label "Indication"
          unit "counts"
          measurement_method direct
          required true
        }
        field time : string {
          label "Time"
          measurement_method direct
          description "Time of the reading (HH:MM:SS)"
        }
      }
    }
  }

  field average_indication : number {
    label "Average"
    unit "counts"
    measurement_method derived
    derivation "ocl{runs.indication->mean()}"
  }

  field repeatability_error : number {
    label "Repeatability error"
    unit "counts"
    measurement_method derived
    derivation "ocl{runs.indication->max() - runs.indication->min()}"
  }
}

// ─────────────────────────────────────────────────────────────────────
// Forms — declarative TRF schemas (R 60-3)
//
// A representative sample of the 40+ forms in data/oiml-r60/forms/.
// The full form set is in the YAML; these demonstrate the Primmel
// `form` construct with subform composition and OCL evaluation rules.
// ─────────────────────────────────────────────────────────────────────

form LoadCellInfo {
  name "Load cell information (R 60-3 §4.5)"
  description "Identification and parameters of the load cell under test."
  data_class FormInstance#data
  header FormHeaderA

  field manufacturer {
    label "Manufacturer"
    measurement_method declared
    required true
  }

  field type_designation {
    label "Type designation"
    measurement_method declared
    required true
  }

  field emax {
    label "Maximum capacity (Emax)"
    unit "kg"
    measurement_method declared
    required true
  }

  field emin {
    label "Minimum dead load (Emin)"
    unit "kg"
    measurement_method declared
    required true
  }

  field accuracy_class {
    label "Accuracy class"
    type enum
    values [A, B, C, D]
    measurement_method declared
    required true
  }

  field n_lc {
    label "Maximum number of verification intervals (nLC)"
    type integer
    measurement_method declared
    required true
  }

  field y {
    label "Y (Emax / vmin)"
    type integer
    measurement_method declared
  }

  field z {
    label "Z (DR ratio)"
    type integer
    measurement_method declared
  }

  field p_lc {
    label "Apportioning factor (pLC)"
    type number
    default 0.7
    measurement_method declared
  }
}

form LoadTest {
  name "Load test data (R 60-3 Tables 6.3 + 6.4 — parameterized)"
  description "Per-load-point measurements. N is 3 for classes C/D, 5 for classes A/B per R 60-2 §2.10.1."
  data_class FormInstance#data
  header FormHeaderA
  conformance_process DetermineMeasurementError
  applicability {
    accuracy_class: [A, B, C, D]
    n_runs: { A: 5 B: 5 C: 3 D: 3 }
  }

  field electronics_power_voltage {
    label "Power supply voltage"
    measurement_method direct
  }

  field test_loads {
    label "Test load measurements"
    type array
    subform_ref LoadTestRow {
      parameters { n_runs: 3 }
    }
  }

  pass_fail {
    criteria "All |E_L| <= |MPE| at every test load"
    pass_if "ocl{test_loads->forAll(t | t.within_mpe = 'yes')"
  }
}

form LoadCellErrors {
  name "Load cell errors (R 60-3 Table 6.5)"
  description "E_L calculation across four test temperatures (20°C, T_high, T_low, 20°C return)."
  data_class FormInstance#data
  header FormHeaderA
  conformance_process DetermineMeasurementError

  field conversion_factor_f {
    label "Conversion factor (f)"
    type number
    unit "counts/v"
    measurement_method computed
    calculation conversionFactor
  }

  field indication_at_dmin {
    label "Indication at D_min"
    type number
    unit "counts"
    measurement_method direct
  }

  field reference_indication_75pct {
    label "Reference indication at 75%"
    type number
    unit "counts"
    measurement_method direct
  }

  field n_lc {
    label "Number of verification intervals (nLC)"
    type integer
    measurement_method declared
  }

  field dmin {
    label "Minimum test load (D_min)"
    type number
    unit "g, kg, or t"
    measurement_method declared
  }

  field dmax {
    label "Maximum test load (D_max)"
    type number
    unit "g, kg, or t"
    measurement_method declared
  }

  field plc {
    label "Apportioning factor (pLC)"
    type number
    default 0.7
    measurement_method declared
  }

  field temperature_series {
    label "Temperature test series"
    type array
    min_items 4
    max_items 4
    items {
      type object
      fields {
        field temperature : number { label "Temperature" unit "degC" measurement_method direct }
        field test_loads {
          label "Test load measurements"
          type array
          items {
            type object
            fields {
              field test_load : number { label "Test load" unit "g, kg, or t" measurement_method direct }
              field indication : number { label "Indication" unit "counts" measurement_method direct }
              field reference_indication : number {
                label "Reference indication (R_i)"
                type number
                unit "indication units"
                measurement_method computed
                calculation referenceIndication
                calculation_bindings {
                  testLoad: test_load
                  dMin: dmin
                  dMax: dmax
                  n: n_lc
                  f: conversion_factor_f
                }
              }
              field error_EL : number {
                label "Error (E_L)"
                unit "v"
                measurement_method derived
                calculation loadCellError
                calculation_bindings {
                  avgIndication: indication
                  referenceIndication: reference_indication
                  conversionFactor: conversion_factor_f
                }
              }
              field mpe : number {
                label "MPE"
                unit "v"
                measurement_method lookup
              }
              field within_mpe {
                label "Within MPE"
                type enum
                values [yes, no]
                measurement_method evaluated
                evaluation {
                  rule "ocl{abs(error_EL) <= abs(mpe)}"
                  condition "|E_L| <= |MPE|"
                }
              }
            }
          }
        }
      }
    }
  }

  field overall_result {
    label "Overall result"
    type enum
    values [pass, fail]
    measurement_method evaluated
    evaluation {
      rule "ocl{temperature_series->forAll(t | t.test_loads->forAll(l | l.within_mpe = 'yes'))}"
      condition "All |E_L| <= |MPE| at every test load at every temperature"
    }
  }

  pass_fail {
    criteria "All |E_L| <= |MPE| for every test load at every temperature"
    pass_if "ocl{every(within_mpe) = yes}"
  }
}

form CreepDR {
  name "Creep (C_C) and minimum dead load output return (C_DR) — R 60-3 Table 6.8"
  data_class FormInstance#data
  header FormHeaderA
  conformance_process DetermineCreep

  field conversion_factor_f {
    label "Conversion factor (f)"
    type number
    unit "counts/v"
    measurement_method computed
    calculation conversionFactor
  }

  field n_lc {
    label "Number of verification intervals (nLC)"
    type integer
    measurement_method declared
  }

  field dmin {
    label "D_min (minimum test load)"
    type number
    unit "g, kg, or t"
    measurement_method declared
  }

  field dmax {
    label "D_max (maximum test load)"
    type number
    unit "g, kg, or t"
    measurement_method declared
  }

  field initial_dmin_indication {
    label "Initial D_min indication"
    type number
    unit "counts"
    measurement_method direct
  }

  field initial_dmax_indication {
    label "Initial D_max indication"
    type number
    unit "counts"
    measurement_method direct
  }

  field creep_readings {
    label "Creep readings (time series at D_max)"
    type array
    items {
      type object
      fields {
        field test_load : string { measurement_method declared }
        field indication_counts : number { label "Indication" unit "counts" measurement_method direct }
        field indication_time : string { label "Time" measurement_method direct }
        field change_v : number {
          label "Creep change"
          unit "v"
          measurement_method derived
          calculation creep
          calculation_bindings {
            indicationAtTime: indication_counts
            initialIndication: initial_dmax_indication
            conversionFactor: conversion_factor_f
          }
        }
      }
    }
  }

  field dr_readings {
    label "DR readings"
    type array
    items {
      type object
      fields {
        field indication_counts : number { unit "counts" measurement_method direct }
        field indication_time : string { measurement_method direct }
        field change_v : number {
          unit "v"
          measurement_method derived
          calculation deadLoadOutputReturn
          calculation_bindings {
            minLoadIndication2: indication_counts
            minLoadIndication1: initial_dmin_indication
            conversionFactor: conversion_factor_f
          }
        }
      }
    }
  }

  field max_creep_change_v {
    label "Maximum creep change"
    unit "v"
    measurement_method derived
    derivation "ocl{creep_readings->collect(r | r.change_v)->max()}"
  }

  field creep_30min {
    label "Creep at 30 min"
    unit "v"
    measurement_method derived
    derivation "ocl{creep_readings->select(r | r.test_load = 'D_max')->first().change_v}"
  }

  field creep_20min {
    label "Creep at 20 min"
    unit "v"
    measurement_method derived
    derivation "ocl{creep_readings->select(r | r.elapsed_time = '20:00')->first().change_v}"
  }

  field creep_30min_result {
    label "30-min creep result"
    type enum
    values [pass, fail]
    measurement_method evaluated
    evaluation {
      rule "ocl{abs(max_creep_change_v) <= 0.7 * abs(mpe_at_dmax)}"
      condition "|C_C(30 min)| <= 0.7 × |MPE|"
    }
  }

  field dr_value {
    label "DR value"
    unit "v"
    measurement_method derived
    derivation "ocl{dr_readings->collect(r | r.change_v)->last()}"
  }

  field dr_half_v_result {
    label "DR <= 0.5 v result"
    type enum
    values [pass, fail]
    measurement_method evaluated
    evaluation {
      rule "ocl{abs(dr_value) <= 0.5}"
      condition "|C_DR| <= 0.5 v"
    }
  }

  pass_fail {
    criteria "30-min creep C_C(t) <= 0.7 × |MPE|; C_DR <= 0.5 v"
    pass_if "ocl{creep_30min_result = 'pass' and dr_half_v_result = 'pass'}"
  }
}

form HumidityCH {
  name "Humidity effects for CH or unmarked load cells (R 60-3 Table 6.10.1)"
  data_class FormInstance#data
  header FormHeaderB
  conformance_process DetermineHumidityCH
  applicability { humidity_class: [CH] }

  field conversion_factor_f {
    type number
    unit "counts/v"
    measurement_method computed
    calculation conversionFactor
  }

  field nlc {
    type integer
    measurement_method declared
  }

  field dmin {
    type number
    unit "g, kg, or t"
    measurement_method declared
  }

  field dmax {
    type number
    unit "g, kg, or t"
    measurement_method declared
  }

  field summary {
    label "Humidity effects summary"
    type object
    fields {
      field test_loads {
        label "Per-load-point readings"
        type array
        items {
          type object
          fields {
            field test_load : number { unit "g, kg, or t" measurement_method direct }
            field indication_before : number { unit "counts" measurement_method direct }
            field indication_after : number { unit "counts" measurement_method direct }
            field change_v : number {
              unit "v"
              measurement_method derived
              derivation "ocl{(indication_after - indication_before) / conversion_factor_f}"
            }
          }
        }
      }

      field chmin {
        label "C_Hmin"
        unit "v"
        measurement_method derived
        calculation humidityCHmin
      }

      field chmin_limit {
        label "C_Hmin limit (4% n_LC)"
        unit "v"
        measurement_method derived
        derivation "ocl{0.04 * nlc}"
      }

      field chmin_result {
        type enum
        values [pass, fail]
        measurement_method evaluated
        evaluation {
          rule "ocl{abs(chmin) <= chmin_limit}"
          condition "|C_Hmin| <= 4% × n_LC"
        }
      }

      field chmax {
        label "C_Hmax"
        unit "v"
        measurement_method derived
        calculation humidityCHmax
      }

      field chmax_result {
        type enum
        values [pass, fail]
        measurement_method evaluated
        evaluation {
          rule "ocl{abs(chmax) <= abs(mpe)}"
          condition "|C_Hmax| <= |MPE|"
        }
      }
    }
  }

  // Load test before humidity (parameterized subform composition)
  field load_test_before {
    label "Load test before humidity exposure"
    type array
    applicability { phase: before }
    subform_ref LoadTestRow {
      parameters { n_runs: 3 }
    }
  }

  field load_test_after {
    label "Load test after humidity exposure"
    type array
    applicability { phase: after }
    subform_ref LoadTestRow {
      parameters { n_runs: 3 }
    }
  }

  field overall_result {
    label "Overall result"
    type enum
    values [pass, fail]
    measurement_method evaluated
    evaluation {
      rule "ocl{summary.chmin_result = 'pass' and summary.chmax_result = 'pass'}"
      condition "C_Hmin <= 4% × n_LC AND C_Hmax <= |MPE|"
    }
  }

  pass_fail {
    criteria "C_Hmin <= 4% × n_LC; C_Hmax <= |MPE|"
    pass_if "ocl{summary.chmin_result = 'pass' and summary.chmax_result = 'pass'}"
  }
}

