form ESD {
  name "ESD (r60-3/form-6.16)"
  description "Electrostatic discharge test - direct and indirect application"
  conformance_process conf_electronic_tests_esd
  field conversion_factor_f : number { label "Conversion Factor F" unit "counts/v" required true }
  field dmin_value : number { label "Dmin Value" unit "g, kg, or t" }
  field discharge_types : object {
    field contact_discharges : enum { label "Contact Discharges" values [yes, no] }
    field paint_penetration : enum { label "Paint Penetration" values [yes, no] }
    field air_discharges : enum { label "Air Discharges" values [yes, no] }
    field polarity : enum { label "Polarity" values [positive, negative] }
  }
  field direct_application : array {
    items {
      type object
      fields {
        field test_load : number { label "Test Load" unit "g, kg, or t" }
        field test_voltage_kv : number { label "Test Voltage Kv" unit "kV" }
        field no_of_discharges : integer { label "No Of Discharges" }
        field repetition_interval_s : number { label "Repetition Interval S" unit "s" }
        field indication : number { label "Indication" unit "counts" }
        field difference : number { label "Difference" unit "v" calculation ocl{(indication - indication_without) / conversion_factor_f} }
        field significant_fault : enum { label "Significant Fault" values [no, yes] calculation ocl{abs(difference) > vmin ? ''yes'' : ''no''} }
        field remarks : string { label "Remarks" }
      }
    }
  }
  field horizontal_coupling_plane : array {
    items {
      type object
      fields {
        field test_load : number { label "Test Load" unit "g, kg, or t" }
        field test_voltage_kv : number { label "Test Voltage Kv" unit "kV" }
        field no_of_discharges : integer { label "No Of Discharges" }
        field repetition_interval_s : number { label "Repetition Interval S" unit "s" }
        field indication : number { label "Indication" unit "counts" }
        field difference : number { label "Difference" unit "v" calculation ocl{(indication - indication_without) / conversion_factor_f} }
        field significant_fault : enum { label "Significant Fault" values [no, yes] calculation ocl{abs(difference) > vmin ? ''yes'' : ''no''} }
        field remarks : string { label "Remarks" }
      }
    }
  }
  field vertical_coupling_plane : array {
    items {
      type object
      fields {
        field test_load : number { label "Test Load" unit "g, kg, or t" }
        field test_voltage_kv : number { label "Test Voltage Kv" unit "kV" }
        field no_of_discharges : integer { label "No Of Discharges" }
        field repetition_interval_s : number { label "Repetition Interval S" unit "s" }
        field indication : number { label "Indication" unit "counts" }
        field difference : number { label "Difference" unit "v" calculation ocl{(indication - indication_without) / conversion_factor_f} }
        field significant_fault : enum { label "Significant Fault" values [no, yes] calculation ocl{abs(difference) > vmin ? ''yes'' : ''no''} }
        field remarks : string { label "Remarks" }
      }
    }
  }
  field test_points : object {
    field direct_contact_discharges : text { label "Direct Contact Discharges" }
    field direct_air_discharges : text { label "Direct Air Discharges" }
    field indirect_application : text { label "Indirect Application" }
  }
  field remarks : text { label "Remarks" }
  field overall_result : enum { label "Overall Result" required true values [pass, fail] }
  pass_fail {
    criteria "No significant fault (> v_min)"
    pass_if "ocl{every(significant_fault) = no}"
  }
}

form HumiditySH {
  name "HumiditySH (r60-3/table-6.10.2)"
  description "Humidity effects for SH marked load cells"
  conformance_process conf_metrological_tests_humidity_sh
  field conversion_factor_f : number { label "Conversion Factor F" unit "counts/v" required true measurement_method computed calculation conversionFactor }
  field reference_indication_75pct : number { label "Reference indication at 75%" unit "counts" required true measurement_method direct }
  field indication_at_dmin : number { label "Indication at D_min" unit "counts" required true measurement_method direct }
  field dmin : number { label "Minimum test load (D_min)" unit "g, kg, or t" required true measurement_method declared }
  field dmax : number { label "Maximum test load (D_max)" unit "g, kg, or t" required true measurement_method declared }
  field nlc : integer { label "Number of verification intervals (n_LC)" required true measurement_method declared }
  field plc : number { label "Apportionment factor (p_LC)" measurement_method declared default 0.7 }
  field page_load_test_before : string { label "Page of Load Test Before Humidity" }
  field page_load_test_during : string { label "Page of Load Test During Humidity" }
  field page_load_test_after : string { label "Page of Load Test After Humidity" }
  field test_loads : array {
    items {
      type object
      fields {
        field test_load : number { label "Test Load" unit "g, kg, or t" required true }
        field reference_indication : number { label "Reference Indication" unit "counts" measurement_method computed calculation referenceIndication }
        field condition_20c_50rh : object {
          field temperature : number { label "Temperature" unit "degC" }
          field humidity : number { label "Humidity" unit "%" }
          field indication : number { label "Indication" unit "counts" }
          field error_EL : number { label "Error (E_L)" unit "v" measurement_method derived calculation loadCellError }
        }
        field condition_high_85rh : object {
          field temperature : number { label "Temperature" unit "degC" }
          field humidity : number { label "Humidity" unit "%" }
          field indication : number { label "Indication" unit "counts" }
          field error_EL : number { label "Error (E_L)" unit "v" measurement_method derived calculation loadCellError }
        }
        field condition_20c_return : object {
          field temperature : number { label "Temperature" unit "degC" }
          field humidity : number { label "Humidity" unit "%" }
          field indication : number { label "Indication" unit "counts" }
          field error_EL : number { label "Error (E_L)" unit "v" measurement_method derived calculation loadCellError }
        }
        field mpe : number { label "MPE" unit "v" measurement_method lookup calculation mpe }
      }
    }
  }
  field overall_result : enum { label "Overall Result" required true values [pass, fail] }
  pass_fail {
    criteria "All |E_L| <= |MPE| at all humidity conditions"
    pass_if "ocl{every(error_EL) <= every(mpe)}"
  }
}

form InitialTests {
  name "InitialTests (r60-3/sec-6.2)"
  description "Initial tests and general notes — units, measurement range, conditions, input impedance"
  field test_units : array {
    items {
      type object
      fields {
        field r60_reference : string { label "R 60-2 reference" }
        field test_procedure : string { label "Test procedure" }
        field unit : string { label "Unit" }
      }
    }
  }
  field measurement_range : array {
    items {
      type object
      fields {
        field test_procedure_ref : string { label "Test procedure (R 60-2 ref)" }
        field dmax : number { label "D_max" }
        field dmin : number { label "D_min" }
        field conversion_factor_f : number { label "Conversion factor (f)" }
        field fulfils_requirements : enum { label "Fulfils requirements" }
      }
    }
  }
  field measurement_range_passed : enum { label "Measurement range passed" }
  field conditions_check : array {
    items {
      type object
      fields {
        field test_procedure_ref : string { label "Test procedure (R 60-2 ref)" }
        field dmin : number { label "D_min" }
        field dmax : number { label "D_max" }
        field nlc : integer { label "n_LC" }
        field check_nlc : enum { label "Fulfilled with n_LC" }
        field check_nlc_500 : enum { label "Fulfilled with n_LC - 500" }
        field check_nlc_1000 : enum { label "Fulfilled with n_LC - 1000" }
      }
    }
  }
  field conditions_passed : enum { label "Conditions passed" }
  field input_impedance : object {
    field measured_value : number { label "Measured value" unit "Ohm" }
    field specified_value : number { label "Specified value" unit "Ohm" }
    field within_spec : enum { label "Within specification" }
  }
}

form LoadCellTypeInfo {
  name "LoadCellTypeInfo (r60-3/sec-4.5)"
  description "General information concerning the load cell type"
  field manufacturer_name_trademark : string { label "Manufacturer Name Trademark" required true }
  field type_designation : string { label "Type Designation" required true }
  field accuracy_classes : array { label "Accuracy Classes" required true }
  field nlc : integer { label "Nlc" required true }
  field emax : number { label "Emax" unit "g, kg, or t" required true }
  field emin : number { label "Emin" unit "g, kg, or t" }
  field vmin : number { label "Vmin" unit "g, kg, or t" calculation ocl{(emax - emin) / Y} }
  field DR : number { label "DR" unit "g, kg, or t" calculation ocl{0.5 * (emax - emin) / Z} }
  field rated_output : string { label "Rated Output" unit "mV/V or counts" }
  field input_impedance : string { label "Input Impedance" unit "Ohm" }
}

form ManufacturerInfo {
  name "ManufacturerInfo (r60-3/sec-4.4)"
  description "General information regarding the evaluation process - manufacturer and applicant"
  field manufacturer : object {
    field company : string { label "Company" required true }
    field address : string { label "Address" }
    field contact_information : string { label "Contact Information" }
  }
