form BarometricPressure {
  name "BarometricPressure (r60-3/table-6.9)"
  description "Barometric pressure effects (C_P)"
  conformance_process conf_metrological_tests_barometric_pressure
  field conversion_factor_f : number { label "Conversion factor (f)" unit "counts/v" required true measurement_method computed calculation conversionFactor }
  field reference_indication_75pct : number { label "Reference indication at 75%" unit "counts" required true measurement_method direct }
  field indication_at_dmin : number { label "Indication at D_min" unit "counts" required true measurement_method direct }
  field n_lc : integer { label "Number of verification intervals (n_LC)" required true measurement_method declared }
  field vmin : number { label "Minimum verification interval (v_min)" unit "g, kg, or t" required true measurement_method declared }
  field pressure_readings : array {
    items {
      type object
      fields {
        field pressure : number { label "Pressure" unit "kPa" required true measurement_method direct }
        field indication : number { label "Indication" unit "counts" required true measurement_method direct }
        field time : string { label "Time" measurement_method direct }
        field change_v : number { label "Change (v)" unit "v" measurement_method derived calculation barometricPressureEffect }
        field change_per_kpa : number { label "Change (v_min/kPa)" unit "v_min/kPa" measurement_method derived derivation "ocl{if $index = 0 then 0 else change_v / abs(pressure - $prev.pressure) endif}" }
        field mpc : number { label "MPC (v_min/kPa)" unit "v_min/kPa" measurement_method declared derivation "ocl{$context.v_min}" }
        field within_mpc : enum { label "Within MPC" measurement_method evaluated }
      }
    }
  }
  field overall_result : enum { label "Overall result" required true measurement_method evaluated values [pass, fail] }
  pass_fail {
    criteria "C_P(v_min) <= v_min per 1 kPa"
    pass_if "ocl{pressure_readings->forAll(r | r.within_mpc = 'yes')}"
  }
}

form Bursts {
  name "Bursts (r60-3/form-6.14)"
  description "Bursts (electrical fast transients) test - power supply lines and I/O circuits"
  conformance_process conf_electronic_tests_bursts
  field conversion_factor_f : number { label "Conversion Factor F" unit "counts/v" required true }
  field dmin_value : number { label "Dmin Value" unit "g, kg, or t" }
  field power_supply_lines : array {
    items {
      type object
      fields {
        field test_load : number { label "Test Load" unit "g, kg, or t" }
        field connection : enum { label "Connection" values [L_ground, N_ground, PE_ground] }
        field polarity : enum { label "Polarity" values [positive, negative] }
        field indication : number { label "Indication" unit "counts" }
        field difference : number { label "Difference" unit "v" calculation ocl{(indication - indication_without_disturbance) / conversion_factor_f} }
        field significant_fault : enum { label "Significant Fault" values [no, yes] calculation ocl{abs(difference) > vmin ? ''yes'' : ''no''} }
        field remarks : string { label "Remarks" }
      }
    }
  }
  field io_circuits : array {
    items {
      type object
      fields {
        field test_load : number { label "Test Load" unit "g, kg, or t" }
        field cable_interface : string { label "Cable Interface" }
        field polarity : enum { label "Polarity" values [positive, negative] }
        field indication : number { label "Indication" unit "counts" }
        field difference : number { label "Difference" unit "v" calculation ocl{(indication - indication_without_disturbance) / conversion_factor_f} }
        field significant_fault : enum { label "Significant Fault" values [no, yes] calculation ocl{abs(difference) > vmin ? ''yes'' : ''no''} }
        field remarks : string { label "Remarks" }
      }
    }
  }
  field equipment_used : text { label "Equipment Used" }
  field remarks : text { label "Remarks" }
  field overall_result : enum { label "Overall Result" required true values [pass, fail] }
  pass_fail {
    criteria "No significant fault (> v_min) or fault detected and acted upon"
    pass_if "ocl{every(significant_fault) = no}"
  }
}

