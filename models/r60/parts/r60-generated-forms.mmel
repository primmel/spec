    field company : string { label "Company" }
    field representative : string { label "Representative" }
    field address : string { label "Address" }
    field contact_information : string { label "Contact Information" }
    field reference : string { label "Reference" }
    field date_of_application : date { label "Date Of Application" }
    field application_number : string { label "Application Number" }
    field authorised_by_manufacturer : enum { label "Authorised By Manufacturer" values [yes, no] }
    field no_concurrent_application : enum { label "No Concurrent Application" values [yes, no] }
    field remarks : text { label "Remarks" }
  }
  field testing_laboratories : array {
    items {
      type object
      fields {
        field name : string { label "Name" }
        field address : string { label "Address" }
        field application_number : string { label "Application Number" }
        field tests_by_lab : string { label "Tests By Lab" }
        field date_period : string { label "Date Period" }
        field test_engineers : string { label "Test Engineers" }
        field accredited_by : string { label "Accredited By" }
        field accreditation_number : string { label "Accreditation Number" }
        field accreditation_expires : date { label "Accreditation Expires" }
        field accreditation_includes_r60 : enum { label "Accreditation Includes R60" values [yes, no] }
        field accreditation_edition : string { label "Accreditation Edition" }
        field peer_assessment_details : text { label "Peer Assessment Details" }
        field offsite_test_details : text { label "Offsite Test Details" }
        field responsible_person : string { label "Responsible Person" }
        field signature_date : date { label "Signature Date" }
        field stamp_signature : string { label "Stamp Signature" }
        field remarks : text { label "Remarks" }
      }
    }
  }
}

form MarkingExamination {
  name "MarkingExamination (r60-3/sec-5.1)"
  description "Marking requirements examination (R 60-1, 6.2)"
  conformance_process conf_examinations_inscriptions
  field mandatory_markings_on_load_cell : array {
    items {
      type object
      fields {
        field r60_reference : string { label "R 60 reference" }
        field information : string { label "Information" }
        field fulfils_requirements : enum { label "Fulfils requirements" values [yes, no] }
      }
    }
  }
  field mandatory_markings_on_load_cell_or_document : array {
    items {
      type object
      fields {
        field r60_reference : string { label "R 60 reference" }
        field information : string { label "Information" }
        field on_load_cell : enum { label "On load cell" values [yes, no] }
        field in_document : enum { label "In document" values [yes, no] }
        field fulfils_requirements : enum { label "Fulfils requirements" values [yes, no] }
      }
    }
  }
  pass_fail {
    criteria "All mandatory markings present and correct"
    pass_if "ocl{every(fulfils_requirements) = 'yes'}"
  }
}

form ModelRangeInfo {
  name "ModelRangeInfo (r60-3/sec-4.11)"
  description "Documentation of the model range — various designs within the model range, relevant photographs of the range, definition of load cell families/construction, load cell dimensions within the family, and"
  field model_range_designs : array {
    items {
      type object
      fields {
        field designation : string { label "Design designation" measurement_method declared }
        field description : text { label "Description" measurement_method declared }
        field capacities : string { label "Capacities covered" measurement_method declared }
      }
    }
  }
  field family_definition : object {
    field construction_type : string { label "Construction type" measurement_method declared }
    field sealing_method : string { label "Sealing method" measurement_method declared }
    field strain_gauge_type : string { label "Strain gauge type" measurement_method declared }
    field material : string { label "Material" measurement_method declared }
  }
  field dimensions : array {
    items {
      type object
      fields {
        field model_designation : string { label "Model designation" measurement_method declared }
        field height : number { label "Height" unit "mm" measurement_method declared }
        field diameter : number { label "Diameter (or width)" unit "mm" measurement_method declared }
        field weight : number { label "Weight" unit "kg" measurement_method declared }
        field drawing_reference : string { label "Drawing reference" measurement_method declared }
      }
    }
  }
  field recommended_load_transmissions : array {
    items {
      type object
      fields {
        field load_direction : enum { label "Load direction" measurement_method declared values [compression, tension, beam, universal] }
        field mounting_hardware : string { label "Mounting hardware" measurement_method declared }
        field loading_fixture : string { label "Loading fixture" measurement_method declared }
        field notes : text { label "Notes" measurement_method declared }
      }
    }
  }
}

form PerformanceTestSummary {
  name "PerformanceTestSummary (r60-3/sec-6.1)"
  description "Results of the performance tests — data-derived from test form instances"
  field base_tests : array {
    items {
