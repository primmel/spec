form AuthorityInfo {
  name "AuthorityInfo (r60-3/sec-4.1)"
  description "Issuing authority responsible for the evaluation report"
  field authority_name : string { label "Authority Name" required true }
  field address : string { label "Address" required true }
  field report_number : string { label "Report Number" required true }
  field application_number : string { label "Application Number" required true }
  field period_of_tests : string { label "Period Of Tests" }
  field date_of_issuing : date { label "Date Of Issuing" required true }
