        field used_for_2_10_4 : enum { label "Used For 2 10 4" values [yes, no] }
        field used_for_2_10_5 : enum { label "Used For 2 10 5" values [yes, no] }
        field used_for_2_10_6 : enum { label "Used For 2 10 6" values [yes, no] }
        field used_for_2_10_7 : enum { label "Used For 2 10 7" values [yes, no] }
      }
    }
