  name "SummaryResults (r60-3/sec-4.3)"
  description "Summary of examination and test results — data-derived from completed form instances"
  field examination_results : array {
    items {
      type object
      fields {
        field form_id : string { label "Form" }
        field test_name : string { label "Test" required true }
        field passed : boolean { label "Passed" }
        field failed : boolean { label "Failed" }
        field details_reference : string { label "Details in R 60" }
      }
    }
  }
  field performance_results : array {
    items {
      type object
      fields {
        field form_id : string { label "Form" }
        field test_name : string { label "Test" required true }
        field temperatures : string { label "Temperature" }
        field passed : boolean { label "Passed" }
        field failed : boolean { label "Failed" }
        field max_error_v : number { label "Max Error V" unit "v" }
        field details_reference : string { label "Details in R 60" }
        field remark : string { label "Remark" }
      }
    }
  }
  field electronic_results : array {
    items {
      type object
      fields {
        field form_id : string { label "Form" }
        field test_name : string { label "Test" required true }
        field passed : boolean { label "Passed" }
        field failed : boolean { label "Failed" }
        field max_error_v : number { label "Max Error V" unit "v" }
        field details_reference : string { label "Details in R 60" }
        field remark : string { label "Remark" }
      }
    }
  }
}

form Surge {
  name "Surge (r60-3/form-6.15)"
  description "Surge test"
  conformance_process conf_electronic_tests_surge
  field conversion_factor_f : number { label "Conversion Factor F" unit "counts/v" required true }
  field dmin_value : number { label "Dmin Value" }
  field unit : enum { label "Unit" values [g, kg, t] }
  field test_conditions : object {
    field output_gained_method : enum { label "Output Gained Method" values [actual_loads, simulating_loading] }
    field simulating_using : string { label "Simulating Using" }
    field cable_type : enum { label "Cable Type" values [symmetrical, unsymmetrical] }
    field line_to_line_kv : number { label "Line To Line Kv" unit "kV" }
    field line_to_earth_kv : number { label "Line To Earth Kv" unit "kV" }
    field test_load_value : number { label "Test Load Value" }
  }
  field test_cycles : array {
    items {
      type object
      fields {
        field cycle_phase : enum { label "Cycle Phase" values [initial, during_exposure, after] }
        field load : number { label "Load" }
        field time_start : string { label "Time Start" }
        field time_stop : string { label "Time Stop" }
        field reference : number { label "Reference" }
        field indicated : number { label "Indicated" }
        field error : number { label "Error" unit "v_min" }
        field relative_error_pct : number { label "Relative Error Pct" unit "%" }
        field mpe_pct : number { label "Mpe Pct" unit "%" }
      }
    }
  }
  field observed_faults : array {
    items {
      type object
      fields {
        field fault_type : enum { label "Fault Type" values [line_to_line_up, line_to_line_down, line_to_earth_up, line_to_earth_down] }
        field fault_limit_pct : number { label "Fault Limit Pct" unit "%" }
        field fault_deviation : string { label "Fault Deviation" }
        field significant : enum { label "Significant" values [yes, no] }
        field acts_on_fault : enum { label "Acts On Fault" values [yes, no] }
      }
    }
  }
  field observations : text { label "Observations" }
  field overall_result : enum { label "Overall Result" required true values [pass, fail] }
  pass_fail {
    criteria "No significant fault or fault detected and acted upon"
    pass_if "ocl{every(significant) = no or every(acts_on_fault) = yes}"
  }
}

form Synopsis {
  name "Synopsis (r60-3/sec-4.2)"
  description "Synopsis of examination and test results"
  field fulfils_all_requirements : enum { label "Fulfils All Requirements" required true values [yes, no] }
  field remarks : text { label "Remarks" }
}

form TemperatureMDLO {
  name "TemperatureMDLO (r60-3/table-6.7)"
  description "Temperature effects on minimum dead load output (C_M)"
  conformance_process conf_metrological_tests_measurement_error_repeatability_mdlo
  field conversion_factor_f : number { label "Conversion factor (f)" unit "counts/v" required true measurement_method computed calculation conversionFactor }
  field reference_indication_75pct : number { label "Reference indication at 75%" unit "counts" required true measurement_method direct }
  field indication_at_dmin : number { label "Indication at D_min" unit "counts" required true measurement_method direct }
  field n_lc : integer { label "Number of verification intervals (n_LC)" required true measurement_method declared }
  field plc : number { label "Apportionment factor (p_LC)" measurement_method declared default 0.7 }
  field temperature_readings : array {
    items {
      type object
      fields {
        field temperature : number { label "Temperature" unit "degC" required true measurement_method direct }
        field indication : number { label "Indication" unit "counts" required true measurement_method direct }
        field change_v : number { label "Change (v)" unit "v" measurement_method derived derivation "ocl{if $index = 0 then 0 else (indication - $prev.indication) / conversion_factor_f endif}" }
        field change_per_5deg : number { label "Change per 5 degC" unit "v" measurement_method derived derivation "ocl{if $index = 0 then 0 else change_v * 5 / abs(temperature - $prev.temperature) endif}" }
        field mpc : number { label "MPC" unit "v" measurement_method declared derivation "ocl{$context.p_LC}" }
        field within_mpc : enum { label "Within MPC" measurement_method evaluated }
      }
    }
  }
  field overall_result : enum { label "Overall result" required true measurement_method evaluated values [pass, fail] }
  pass_fail {
    criteria "C_M(v) per 5 degC <= p_LC for classes B/C/D; per 2 degC for class A"
    pass_if "ocl{temperature_readings->forAll(r | r.within_mpc = 'yes')}"
  }
}

